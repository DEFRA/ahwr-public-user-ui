{% extends './layouts/layout.njk' %}

{% block pageTitle %}Minimum number of poultry in the unit - {{ serviceName }} - GOV.UK{% endblock %}

{% block beforeContent %}
{{ govukBackLink({
text: "Back",
href: backLink,
attributes: {id: "back"}
}) }}
{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">Minimum number of poultry in the unit</h1>
    <p class="govuk-body">Each time you do a biosecurity review of the unit, you must have the minimum number of poultry. The minimum needed for the unit is:</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>1,000 broilers</li>
      <li>1,000 laying hens</li>
      <li>500 ducks</li>
      <li>500 geese</li>
      <li>500 turkeys</li>
    </ul>
    <br>

    <form method="POST" autocomplete="off" novalidate="novalidate" id="submitNumbersForm">
      <input type="hidden" name="crumb" value="{{crumb}}" />
      <div class="govuk-button-group">
        {{ govukButton({
        text: "I agree",
        attributes: { "aria-label": "I agree - Minimum number of poultry requirements" },
        value: "agree",
        name: "agreementStatus",
        preventDoubleClick: true
        }) }}

        {{ govukButton({
        text: "I do not agree",
        attributes: { "aria-label": "I do not agree - Minimum number of poultry requirements" },
        value: "notAgree",
        name: "agreementStatus",
        preventDoubleClick: true,
        classes: "govuk-button--secondary"
        }) }}
      </div>
    </form>
  </div>
</div>
{% endblock %}
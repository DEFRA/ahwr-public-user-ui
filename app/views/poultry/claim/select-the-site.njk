{% extends './layouts/layout.njk' %}

{% block pageTitle %}{% if errorMessage %}Error: {% endif %}{{pageTitleText}} - {{serviceName}} - GOV.UK{% endblock %}

{% block beforeContent %}
  {{ govukBackLink({
    text: "Back",
    href: backLink,
    attributes: {
      id: "back"
    }
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorMessage %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [errorMessage]
          }) }}
      {% endif %}

      <form method="POST" autocomplete="off" novalidate="novalidate">
        <input type="hidden" name="crumb" value="{{crumb}}"/>

        {% if sites.length == 1 %}
          <h1 class="govuk-heading-l">{{ pageTitleText }}</h1>
          {{
            govukSummaryList({
              rows: [
                {
                  key: {
                    text: "Types of poultry"
                  },
                  value: {
                    text: species
                  }
                },
                {
                  key: {
                    text: "Site name"
                  },
                  value: {
                    text: name
                  }
                },
                {
                  key: {
                    text: "CPH number for site"
                  },
                  value: {
                    text: cphNumber
                  }
                },
                {
                  key: {
                    text: "Last visit date"
                  },
                  value: {
                    text: lastVisitDate
                  }
                },
                {
                  key: {
                    text: "Claim date"
                  },
                  value: {
                    text: claimDate
                  }
                }
              ]
            }) 
          }}
          {{ 
            govukRadios({
              id: "siteSelected",
              name: "siteSelected",
              fieldset: {
                legend: {
                  text: "Are you making another claim for the same site?",
                  classes: "govuk-fieldset__legend--m"
                }
              },
              hint: {
                text: "You can have reviews on more than one site."
              },
              errorMessage: errorMessage,
              items: [
                {
                  value: siteId,
                  text: "Yes, I'm claiming for the same site",
                  checked: siteSelected == siteId
                },
                {
                  value: radioValueNewSite,
                  text: "No, I'm claiming for a different site",
                  checked: siteSelected == radioValueNewSite
                }
              ]
            })
          }}
        {% else %}
          {% set siteItems = [] %}
          {% for item in sites %}
            {% set siteItems = siteItems.concat([{ value: item.id, text: item.name, hint: {text: "CPH: " ~ item.cph}, checked: siteSelected == item.id }]) %}
          {% endfor %}
          {% set siteItems = siteItems.concat([{ divider: "or" }]) %}
          {% set siteItems = siteItems.concat([{ value: radioValueNewSite, text: "I am claiming for a different site", checked: siteSelected == radioValueNewSite }]) %}
          {{ 
            govukRadios({
              id: "siteSelected",
              name: "siteSelected",
              fieldset: {
                legend: {
                  isPageHeading: true,
                  classes: "govuk-fieldset__legend--l",
                  text: pageTitleText
                }
              }, 
              hint: {
                text: "You can also choose to claim for a different site"
              }, 
              errorMessage: errorMessage,
              items: siteItems
            })
          }}
        {% endif %}

        {{ govukButton({
          text: "Continue",
          attributes: { id: "btnContinue" },
          preventDoubleClick: true
        }) 
      }}
      </form>
    </div>
  </div>
{% endblock %}
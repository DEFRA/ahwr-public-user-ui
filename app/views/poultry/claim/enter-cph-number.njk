{% extends './layouts/layout.njk' %}

{% block pageTitle %}{% if errorMessage %}Error: {% endif %}Enter the CPH number for this site - {{ serviceName }} - GOV.UK{% endblock %}

{% block beforeContent %}
  {{ govukBackLink({
    text: "Back",
    href: backLink,
    attributes: {
      id: "back"
    }
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorMessage %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [errorMessage]
        }) }}
      {% endif %}

      <form method="POST" autocomplete="off" novalidate="novalidate">
        <input type="hidden" name="crumb" value="{{crumb}}"/>
        {{ govukInput({
          label: {
              text: "Enter the County Parish Holding (CPH) number for this site",
              classes: "govuk-label--l",
              isPageHeading: true
            },
            hint: {
              html: "Tell us the CPH for this site. You cannot use the same CPH for two sites.<span class='govuk-!-display-block govuk-!-margin-top-2'>CPH format should be nn/nnn/nnnn</span>"
            },
            classes: "govuk-input",
            id: "herdCph",
            name: "herdCph",
            value: herdCph,
            errorMessage: errorMessage
            }) 
        }}
        {{ govukButton({
            text: "Continue",
            attributes: { id: "btnContinue" },
            preventDoubleClick: true
          }) 
        }}
      </form>
    </div>
  </div>
{% endblock %}
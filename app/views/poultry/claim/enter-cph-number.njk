{% extends './layouts/layout.njk' %}

{% block pageTitle %}{% if errorMessage %}Error: {% endif %}Enter the CPH number for this site - {{ serviceName }} - GOV.UK{% endblock %}

{% block containerStart %}
  {{ govukBackLink({
    text: "Back",
    href: backLink,
    attributes: {
      id: "back"
    }
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorMessage %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [errorMessage]
        }) }}
      {% endif %}

      <form method="POST" autocomplete="off" novalidate="novalidate">
        <input type="hidden" name="crumb" value="{{crumb}}"/>
        {{ govukInput({
          label: {
              text: "Enter the county parish holding (CPH) number for this site",
              classes: "govuk-label--l",
              isPageHeading: true
            },
            hint: {
              html: "For example, 12/345/6789"
            },
            classes: "govuk-input",
            id: "herdCph",
            name: "herdCph",
            value: herdCph,
            errorMessage: errorMessage
            }) 
        }}
        {{ govukButton({
            text: "Continue",
            attributes: { id: "btnContinue" },
            preventDoubleClick: true
          }) 
        }}
      </form>
    </div>
  </div>
{% endblock %}
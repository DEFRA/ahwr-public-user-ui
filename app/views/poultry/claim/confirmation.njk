{% extends './layouts/layout.njk' %}

{% block pageTitle %}Claim submitted - {{ serviceName }} - GOV.UK{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukPanel({
      titleText: "Claim submitted",
      html: "Your claim number:<br><strong id=reference>" + reference + "</strong>"
    }) }}
      <p id="message" class="govuk-!-margin-top-6">You have successfully submitted your claim for a poultry biosecurity review.</p>
      <p>We've sent you a confirmation email.</p>
      <h2 class="govuk-heading-m">What happens next</h2>
      <p id="amount">We will aim to process your claim within 28 days. If your claim is successful, you will get £{{amount}}.</p>
      <p>The Rural Payments Agency (RPA) may contact you to request the summary the vet gave you.</p>
      <p>Go to <a class="govuk-link" rel="external" href={{ claimDashboard }}>manage your claims</a> to:</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>make another claim</li>
        <li>view your claims</li>
      </ul>
      <p>If you want to arrange another poultry biosecurity review, <a class="govuk-link" rel="external" href={{ guidanceUri }} >read the guidance</a> to find out how often you can claim.</p>
      <h2 class="govuk-heading-m">Get help with your claim</h2>
      <p>If you need to change the details of your claim, contact the RPA and give your agreement number.</p>
      {{ rpaContactDetails({email: ruralPaymentsAgency.email, callChargesUri: ruralPaymentsAgency.callChargesUri, telephone: ruralPaymentsAgency.telephone}) }}
      <br/>
      <p>
        <a class='govuk-link' rel="external noopener noreferrer" target={{ customerSurveyUri }} href={{ customerSurveyUri }}>
        What did you think of this service?
      </a>
      (takes about 5 minutes)
    </p>
    </div>
  </div>
{% endblock %}
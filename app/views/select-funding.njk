{% extends './layouts/layout.njk' %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "./macros/organisation-header.njk" import organisationHeader %}

{% set pageHeadingText='Select funding' %}

{% block pageTitle %}{{ pageHeadingText }} - {{ serviceName }} - GOV.UK{% endblock %}

{% block content %}
{{ organisationHeader({
  name: name,
  sbi: sbi,
  farmerName: farmerName,
  attachedToMultipleBusinesses: attachedToMultipleBusinesses,
  hostname: hostname
}) }}
<br />
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds"> 
      {% if errorMessage %}
        {{ govukErrorSummary({
            titleText: "There is a problem",
            errorList: [errorMessage]
          }) }}
      {% endif %}

    <form method="POST" novalidate="novalidate">
      <input type="hidden" name="crumb" value="{{crumb}}" />

      {{ govukRadios({
        id: "selectFunding",
        name: "type",
        errorMessage: errorMessage,
        fieldset: {
          legend: {
            text: pageHeadingText,
            isPageHeading: true,
            classes: "govuk-fieldset__legend--l"
          }
        },
        items: [
          {
            value: "IAHW",
            html: "<b>Cattle, pig, and sheep review and follow-up</b>",
            hint: {
              html: livestockText
            }
          },
          {
            value: "POUL",
            html: "<b>Poultry biosecurity review</b>",
            hint: {
              html: poultryText
            }
          }
        ]
      }) }}
      
      {{ govukButton({
        text: "Continue",
        attributes: {
          id: "continue"
        },
        preventDoubleClick: true
      }) }}

    </form>

  </div>
</div>
{% endblock %}
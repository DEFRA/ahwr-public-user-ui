{% extends './layouts/layout.njk' %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% set pageHeadingText='Select funding' %}

{% block pageTitle %}{{ pageHeadingText }} - {{ serviceName }} - GOV.UK{% endblock %}

{% block content %}
<div class="govuk-grid-row govuk-width-container">
  <div class="govuk-grid-column-two-thirds govuk-!-static-padding-0">
    <h2 class="govuk-heading-m govuk-!-static-margin-bottom-1">{{ name }}</h2>
    <p class="govuk-body govuk-!-static-margin-bottom-1" id="SBI">
      <span class="govuk-!-font-weight-bold">Single Business Identifier (SBI):</span> {{ sbi }}</br>
      <span class="govuk-!-font-weight-bold">Agreement holder:</span> {{farmerName }}
    </p>
  </div>
  <div class="govuk-grid-column-one-third govuk-!-static-padding-0">
    {% if attachedToMultipleBusinesses %}
    <p class="govuk-!-text-align-right">
      <a id="MBILink" href={{ hostname }}>Claim for a different business</a>
    </p>
    {% endif %}
  </div>
</div>
<hr />
<br />
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds"> 
    <form method="POST" novalidate="novalidate">
      <input type="hidden" name="crumb" value="{{crumb}}" />

      {{ govukRadios({
        name: "type",
        fieldset: {
          legend: {
            text: pageHeadingText,
            isPageHeading: true,
            classes: "govuk-fieldset__legend--l"
          }
        },
        items: [
          {
            value: "IAHW",
            html: "<b>Cattle, pig, and sheep review and follow-up</b>",
            hint: {
              html: livestockText
            }
          },
          {
            value: "POUL",
            html: "<b>Poultry biosecurity review</b>",
            hint: {
              html: poultryText
            }
          }
        ]
      }) }}
      
      {{ govukButton({
        text: "Continue",
        attributes: {
          id: "continue"
        },
        preventDoubleClick: true
      }) }}

    </form>

  </div>
</div>
{% endblock %}